# ==================== DATABASE ====================
# PostgreSQL connection string
# For local development: use localhost or Docker container
# For production (Supabase): use the pooler connection (port 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Direct database URL (bypasses connection pooler)
# Required for Prisma migrations on Supabase
# For local development: same as DATABASE_URL
# For production (Supabase): use direct connection (port 5432)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ==================== AUTHENTICATION ====================
# NextAuth.js configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# ==================== EXTERNAL SERVICES ====================
# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Evolution API (WhatsApp) - Optional
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="your-evolution-api-key"

# ==================== DOCKER (Local Development Only) ====================
# These are only used by docker-compose.yml
POSTGRES_USER="gabi_admin"
POSTGRES_PASSWORD="your-secure-password"
POSTGRES_DB="gabi_studio"
EVOLUTION_SERVER_URL="http://localhost:8080"
