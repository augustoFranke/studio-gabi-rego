# ==================== CRITICAL (app will not start without these) ====================

# PostgreSQL connection string (required by Prisma and health checks)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Direct database URL (bypasses connection pooler, required for Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Auth session signing secret (generate with: openssl rand -base64 32)
# Either NEXTAUTH_SECRET or AUTH_SECRET must be set.
NEXTAUTH_SECRET="your-super-secret-key-change-this"

# Cron endpoint authentication secret
CRON_SECRET="generate-a-long-random-string"

# ==================== OPTIONAL (app starts but features degrade) ====================

# Auth callback URL (used by NextAuth redirects)
NEXTAUTH_URL="http://localhost:3000"

# Canonical app timezone for scheduling and dashboard logic
APP_TIMEZONE="America/Sao_Paulo"

# Allowed origin for API CORS (defaults to NEXTAUTH_URL in production)
CORS_ALLOWED_ORIGIN="http://localhost:3000"

# ==================== PROVIDERS (disabled when missing) ====================

# Resend (Email delivery — disabled without this key)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Evolution API (WhatsApp delivery — disabled unless all three are set)
EVOLUTION_API_URL="https://your-evolution-instance.example.com"
EVOLUTION_API_KEY="your-evolution-api-key"
EVOLUTION_INSTANCE="your-instance-name"

# Country calling code prefixed to phone numbers for WhatsApp (default: 55 / Brazil)
WHATSAPP_COUNTRY_CODE="55"

# Upstash Redis (durable rate limiting — falls back to in-memory per-instance buckets without it)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"
