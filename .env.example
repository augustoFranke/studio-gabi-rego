# ==================== DATABASE ====================
# PostgreSQL connection string
# For local development: use localhost or Docker container
# For production (Supabase): use the transaction pooler (port 6543) with `pgbouncer=true`
# Example format: postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Direct database URL (bypasses connection pooler)
# Required for Prisma migrations on Supabase
# For local development: same as DATABASE_URL
# For production (Supabase): use direct connection (port 5432) if available, or session pooler (port 5432) as a fallback
# Example format: postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ==================== AUTHENTICATION ====================
# NextAuth.js configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"
# Allowed origin for API CORS (defaults to NEXTAUTH_URL in production)
CORS_ALLOWED_ORIGIN="http://localhost:3000"

# ==================== EXTERNAL SERVICES ====================
# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="https://evolution.your-domain.com"
EVOLUTION_API_KEY="evolution_api_key_change_me"
EVOLUTION_INSTANCE="studio"
WHATSAPP_COUNTRY_CODE="55"

# Cron / Scheduling
APP_TIMEZONE="America/Sao_Paulo"
CRON_SECRET="generate-a-long-random-string"

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ==================== DOCKER (Local Development Only) ====================
# These are only used by docker-compose.yml
POSTGRES_USER="gabi_admin"
POSTGRES_PASSWORD="your-secure-password"
POSTGRES_DB="gabi_studio"
