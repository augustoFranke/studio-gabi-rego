{
  "name": "gabi-rego-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && (if [ \"$RUN_MIGRATIONS\" = \"1\" ]; then if [ \"$VERCEL\" = \"1\" ]; then prisma migrate resolve --applied 20250309120000_init || true; fi; prisma migrate deploy; fi) && npm run test:run && next build",
    "pre-commit": "npm run test:run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "docker:start": "./docker/scripts/start.sh",
    "docker:stop": "./docker/scripts/stop.sh",
    "docker:build": "DEPLOYMENT_TARGET=docker docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:backup": "./docker/scripts/backup.sh",
    "scrape:nextfit": "tsx utility/nextfit-scraper.ts",
    "scrape:anamnesis": "tsx utility/scrape-anamnesis.ts",
    "update:plans": "tsx utility/update-plans.ts",
    "extract:prices": "tsx utility/extract-plan-prices.ts",
    "import:schedule": "tsx utility/import-schedule.ts",
    "import:schedule:dry": "tsx utility/import-schedule.ts --dry-run",
    "import:payments:feb2026:dry": "tsx utility/import-payments-feb-2026-docx.ts --dry-run --month 2026-02",
    "import:payments:feb2026:apply": "tsx utility/import-payments-feb-2026-docx.ts --apply --month 2026-02",
    "import:payments:feb2026:rollback": "tsx utility/import-payments-feb-2026-docx.ts --rollback",
    "emails:preview": "tsx utility/preview-emails.ts",
    "cleanup:inactive:preview": "tsx utility/cleanup-inactive-members.ts --preview-only",
    "cleanup:inactive:dry": "tsx utility/cleanup-inactive-members.ts --dry-run",
    "cleanup:inactive": "tsx utility/cleanup-inactive-members.ts",
    "migrate:placeholder-emails:preview": "node --import tsx utility/migrate-placeholder-emails.ts --preview",
    "migrate:placeholder-emails:execute": "node --import tsx utility/migrate-placeholder-emails.ts --execute",
    "migrate:placeholder-emails:execute:dry-run": "node --import tsx utility/migrate-placeholder-emails.ts --execute --dry-run",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.36.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.17.2",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.70.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "husky": "^9.1.7",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.57.0",
    "prisma": "^6.19.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.17"
  }
}
