# ==================== PRODUCTION (Vercel + Supabase) ====================
# Copy these to Vercel Dashboard > Settings > Environment Variables
# Replace [YOUR-PASSWORD] with your actual Supabase database password
# Pooler username format: postgres.<project-ref>
# Transaction pooler: port 6543 (requires `pgbouncer=true`)
# Session pooler: port 5432

# Database - Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.epcteerqdilevbngwjmr:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.epcteerqdilevbngwjmr:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Authentication
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secure-secret-here"
# Use your production domain for auth and email links
NEXTAUTH_URL="https://studiogabirego.com"
# Base URL for links sent by email (profile completion, verification, reset)
NEXT_PUBLIC_APP_URL="https://studiogabirego.com"
# Allowed origin for API CORS
CORS_ALLOWED_ORIGIN="https://studiogabirego.com"

# External Services
RESEND_API_KEY="re_xxxxxxxxxxxx"
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="https://evolution.your-domain.com"
EVOLUTION_API_KEY="evolution_api_key_change_me"
EVOLUTION_INSTANCE="studio"
WHATSAPP_COUNTRY_CODE="55"

# Cron / Scheduling
APP_TIMEZONE="America/Sao_Paulo"
CRON_SECRET="generate-a-long-random-string"
