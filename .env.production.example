# ==================== PRODUCTION (Vercel + Supabase) ====================
# Copy these to Vercel Dashboard > Settings > Environment Variables
# Replace [YOUR-PASSWORD] with your actual Supabase database password

# Database - Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.epcteerqdilevbngwjmr:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.epcteerqdilevbngwjmr:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Authentication
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secure-secret-here"
# Use your production domain for auth and email links
NEXTAUTH_URL="https://studiogabirego.com"
# Base URL for links sent by email (profile completion, verification, reset)
NEXT_PUBLIC_APP_URL="https://studiogabirego.com"

# External Services
RESEND_API_KEY="re_xxxxxxxxxxxx"
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Evolution API (WhatsApp) - Optional
EVOLUTION_API_URL="https://your-evolution-api.fly.dev"
EVOLUTION_API_KEY="your-production-api-key"
